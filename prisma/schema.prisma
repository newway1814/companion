// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResumeSource {
  UPLOAD
  PASTE
}

/// Lifecycle of a practice session. Planned once questions are generated and
/// persisted; in progress once the room opens; completed after the five-question run.
enum InterviewSessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

/// A signed-in account. `id` mirrors the Supabase auth user id.
model User {
  id        String   @id @db.Uuid
  email     String?
  createdAt DateTime @default(now())

  resumes     Resume[]
  targetRoles TargetRole[]
  sessions    InterviewSession[]
}

/// A user's uploaded or pasted resume.
model Resume {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  source      ResumeSource
  rawText     String
  storagePath String?
  parsedProfile Json?
  isActive    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime?

  sessions    InterviewSession[]

  @@index([userId])
}

/// A job/role the user is preparing for.
model TargetRole {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String
  company            String?
  status             String?
  rawText            String
  parsedRequirements Json?
  isActive           Boolean   @default(false)
  createdAt          DateTime  @default(now())
  lastUsedAt         DateTime?

  sessions           InterviewSession[]

  @@index([userId])
}

/// A planned technical project deep-dive practice session: a resume + target
/// role frozen into an ordered set of questions before the interview room opens.
model InterviewSession {
  id           String                 @id @default(uuid()) @db.Uuid
  userId       String                 @db.Uuid
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId     String                 @db.Uuid
  resume       Resume                 @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetRoleId String                 @db.Uuid
  targetRole   TargetRole             @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)
  mode         String                 @default("technical-project-deep-dive")
  status       InterviewSessionStatus @default(PLANNED)
  createdAt    DateTime               @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  questions    InterviewQuestion[]

  @@index([userId])
}

/// One primary question in a session's ordered plan, with the objective it tests
/// and a rubric (evaluation criteria) for grading the eventual answer.
model InterviewQuestion {
  id           String           @id @default(uuid()) @db.Uuid
  sessionId    String           @db.Uuid
  session      InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderIndex   Int
  questionText String
  questionType String           @default("project-deep-dive")
  objective    String
  rubric       Json

  @@unique([sessionId, orderIndex])
  @@index([sessionId])
}
