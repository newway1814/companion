# Companion environment variables.
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# Supabase: Project Settings → API
#   NEXT_PUBLIC_* values are safe to expose to the browser.
#   The service-role key is server-only — never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# Postgres connection strings: Supabase → Project Settings → Database → Connection string
#   DATABASE_URL: pooled connection (PgBouncer, port 6543) used by the app at runtime.
#                 Append ?pgbouncer=true&connection_limit=1
#   DIRECT_URL:   direct connection (port 5432) used by Prisma Migrate.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<host>:5432/postgres"

# Anthropic (Claude) — the AI layer. Get a key at https://console.anthropic.com
#   ANTHROPIC_MODEL is optional; defaults to claude-opus-4-8. Set to
#   claude-sonnet-4-6 or claude-haiku-4-5 to trade quality for lower cost.
ANTHROPIC_API_KEY="<your-anthropic-api-key>"
# ANTHROPIC_MODEL="claude-opus-4-8"
